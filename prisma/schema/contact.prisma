model ContactUs {
  id        String               @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    ContactMessageStatus @default(PENDING)

  respondedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}
