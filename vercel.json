{
  "version": 2,
  "buildCommand": "pnpm exec prisma generate && pnpm exec tsc && node scripts/fix-esm-imports.mjs",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node@3.1.0",
      "includeFiles": "src/templates/**"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.ts"
    }
  ]
}