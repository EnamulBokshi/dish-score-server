<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Continue with Google</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Fraunces:opsz,wght@9..144,600&display=swap"
        rel="stylesheet"
    />
    <style>
        :root {
            --bg-1: #fff9ef;
            --bg-2: #fde4cf;
            --ink: #132a3d;
            --ink-soft: #355068;
            --accent: #ff6b35;
            --accent-2: #0f9d58;
            --card: rgba(255, 255, 255, 0.78);
            --border: rgba(19, 42, 61, 0.15);
            --shadow: 0 24px 60px rgba(19, 42, 61, 0.14);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100dvh;
            font-family: "Space Grotesk", sans-serif;
            color: var(--ink);
            background:
                radial-gradient(1100px 600px at -10% 10%, #ffd2b8 0%, transparent 70%),
                radial-gradient(800px 500px at 110% 90%, #bfead3 0%, transparent 65%),
                linear-gradient(145deg, var(--bg-1), var(--bg-2));
            display: grid;
            place-items: center;
            padding: 20px;
            overflow: hidden;
        }

        .orb {
            position: fixed;
            border-radius: 50%;
            filter: blur(10px);
            pointer-events: none;
            animation: drift 10s ease-in-out infinite alternate;
        }

        .orb-one {
            width: 180px;
            height: 180px;
            top: -40px;
            right: -30px;
            background: rgba(255, 107, 53, 0.2);
        }

        .orb-two {
            width: 220px;
            height: 220px;
            left: -70px;
            bottom: -70px;
            background: rgba(15, 157, 88, 0.18);
            animation-duration: 13s;
        }

        .card {
            width: min(560px, 100%);
            border: 1px solid var(--border);
            border-radius: 24px;
            background: var(--card);
            backdrop-filter: blur(10px);
            box-shadow: var(--shadow);
            padding: 28px;
            transform: translateY(8px);
            opacity: 0;
            animation: reveal 700ms ease forwards;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 16px;
            color: var(--ink-soft);
            font-size: 14px;
            font-weight: 500;
        }

        .dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: linear-gradient(120deg, var(--accent), #f4b400, var(--accent-2));
            box-shadow: 0 0 0 5px rgba(255, 107, 53, 0.15);
        }

        h1 {
            margin: 0;
            font-family: "Fraunces", serif;
            font-size: clamp(1.6rem, 3.8vw, 2.25rem);
            letter-spacing: 0.2px;
            line-height: 1.1;
        }

        .subtitle {
            margin: 10px 0 0;
            color: var(--ink-soft);
            font-size: clamp(0.95rem, 2.3vw, 1.05rem);
        }

        .status-row {
            margin-top: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 14px;
            border-radius: 14px;
            border: 1px solid rgba(19, 42, 61, 0.12);
            background: rgba(255, 255, 255, 0.7);
        }

        .spinner {
            width: 18px;
            height: 18px;
            border-radius: 50%;
            border: 2px solid rgba(19, 42, 61, 0.2);
            border-top-color: var(--accent);
            animation: spin 800ms linear infinite;
            flex-shrink: 0;
        }

        .status-text {
            font-size: 0.95rem;
            color: var(--ink-soft);
        }

        .status-text strong {
            color: var(--ink);
            font-weight: 700;
        }

        .error-box {
            display: none;
            margin-top: 18px;
            border: 1px solid rgba(194, 35, 0, 0.2);
            background: rgba(255, 237, 231, 0.9);
            color: #7d1e00;
            border-radius: 12px;
            padding: 12px;
            font-size: 0.92rem;
            line-height: 1.4;
        }

        .error-box.show {
            display: block;
        }

        .actions {
            margin-top: 16px;
            display: none;
            gap: 10px;
        }

        .actions.show {
            display: flex;
        }

        .btn {
            border: 0;
            border-radius: 11px;
            padding: 10px 16px;
            font-family: "Space Grotesk", sans-serif;
            font-weight: 600;
            cursor: pointer;
            transition: transform 160ms ease, filter 160ms ease;
        }

        .btn-primary {
            background: var(--ink);
            color: #fff;
        }

        .btn-secondary {
            background: rgba(19, 42, 61, 0.08);
            color: var(--ink);
        }

        .btn:hover {
            transform: translateY(-1px);
            filter: brightness(1.04);
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        @keyframes reveal {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes drift {
            from {
                transform: translateY(0) translateX(0) scale(1);
            }

            to {
                transform: translateY(14px) translateX(-10px) scale(1.08);
            }
        }

        @media (max-width: 520px) {
            .card {
                padding: 22px;
                border-radius: 20px;
            }

            .status-row {
                align-items: flex-start;
            }
        }
    </style>
</head>

<body>
    <div class="orb orb-one" aria-hidden="true"></div>
    <div class="orb orb-two" aria-hidden="true"></div>

    <main class="card" role="status" aria-live="polite">
        <div class="brand">
            <span class="dot"></span>
            <span>Dish Score Auth Gateway</span>
        </div>

        <h1>Connecting your Google account</h1>
        <p class="subtitle">
            Please wait while we securely redirect you to Google sign-in.
        </p>

        <div class="status-row">
            <span class="spinner" id="spinner" aria-hidden="true"></span>
            <p class="status-text" id="statusText"><strong>Working...</strong> Creating sign-in session.</p>
        </div>

        <div class="error-box" id="errorBox"></div>

        <div class="actions" id="actions">
            <button class="btn btn-primary" type="button" id="retryBtn">Try Again</button>
            <button class="btn btn-secondary" type="button" id="backBtn">Go Back</button>
        </div>
    </main>
</body>
<script>
    const statusText = document.getElementById("statusText");
    const errorBox = document.getElementById("errorBox");
    const actions = document.getElementById("actions");
    const spinner = document.getElementById("spinner");
    const retryBtn = document.getElementById("retryBtn");
    const backBtn = document.getElementById("backBtn");

    const setErrorState = (message) => {
        if (spinner) spinner.style.display = "none";
        if (statusText) {
            statusText.innerHTML = "<strong>Redirect failed.</strong> We could not connect to Google.";
        }
        if (errorBox) {
            errorBox.textContent = message;
            errorBox.classList.add("show");
        }
        if (actions) actions.classList.add("show");
    };

    const startGoogleRedirect = async () => {
        try {
            const response = await fetch("<%= betterAuthUrl %>/api/auth/sign-in/social", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                },
                credentials: "include",
                body: JSON.stringify({
                    provider: "google",
                    callbackURL: "<%= callbackURL %>",
                }),
            });

            const data = await response.json();

            if (data.url) {
                if (statusText) {
                    statusText.innerHTML = "<strong>Success.</strong> Sending you to Google sign-in...";
                }
                window.location.href = data.url;
                return;
            }

            setErrorState("Error occurred while redirecting to Google. Please try again.");
        } catch (error) {
            const message = error?.message
                ? `Error occurred while redirecting to Google: ${error.message}`
                : "Unexpected error occurred while redirecting to Google.";
            setErrorState(message);
        }
    };

    retryBtn?.addEventListener("click", startGoogleRedirect);
    backBtn?.addEventListener("click", () => window.history.back());

    startGoogleRedirect();
</script>

</html>